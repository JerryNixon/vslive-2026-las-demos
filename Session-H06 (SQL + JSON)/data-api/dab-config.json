{
  "$schema": "https://github.com/Azure/data-api-builder/releases/latest/download/dab.draft.schema.json",
  "data-source": {
    "database-type": "mssql",
    "connection-string": "@env('CRM_CONNECTION_STRING')"
  },
  "runtime": {
    "rest": {
      "enabled": true,
      "path": "/api"
    },
    "graphql": {
      "enabled": true,
      "path": "/graphql"
    },
    "mcp": {
      "enabled": true
    },
    "host": {
      "mode": "development",
      "cors": {
        "origins": ["*"],
        "allow-credentials": false
      }
    }
  },
  "entities": {
    "Contact": {
      "source": {
        "object": "dbo.Contact",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "Contact",
          "plural": "Contacts"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [{ "action": "*" }]
        }
      ],
      "relationships": {
        "addresses": {
          "cardinality": "many",
          "target.entity": "Address",
          "source.fields": ["ContactId"],
          "target.fields": ["ContactId"]
        }
      }
    },
    "Address": {
      "source": {
        "object": "dbo.Address",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "Address",
          "plural": "Addresses"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [{ "action": "read" }]
        }
      ],
      "relationships": {
        "contact": {
          "cardinality": "one",
          "target.entity": "Contact",
          "source.fields": ["ContactId"],
          "target.fields": ["ContactId"]
        }
      }
    }
  }
}
