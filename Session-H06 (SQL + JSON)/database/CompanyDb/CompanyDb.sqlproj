<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" Sdk="Microsoft.Build.Sql/2.0.0">
  <PropertyGroup>
    <Name>CompanyDb</Name>
    <DSP>Microsoft.Data.Tools.Schema.Sql.SqlAzureV12DatabaseSchemaProvider</DSP>
    <ModelCollation>1033, CI</ModelCollation>
    <IsPackable>false</IsPackable>
    <ProjectGuid>{00000000-0000-0000-0000-000000000000}</ProjectGuid>
  </PropertyGroup>
  <ItemGroup>
    <PostDeploy Include="Scripts\PostDeployment.sql" />
  </ItemGroup>
  <ItemGroup>
    <!-- Deployed via PostDeployment.sql (uses Azure SQL-specific sp_invoke_external_rest_endpoint) -->
    <None Include="StoredProcedures\Crm_ImportAll.sql" />
    <None Include="StoredProcedures\Crm_Fetch.sql" />
    <None Include="StoredProcedures\Crm_ParseContacts.sql" />
    <None Include="StoredProcedures\Crm_ParseAddresses.sql" />
    <None Include="StoredProcedures\Crm_Import.sql" />
    <None Include="StoredProcedures\Crm_BuildJson.sql" />
    <None Include="StoredProcedures\Crm_PushToCrm.sql" />
    <None Include="StoredProcedures\Crm_RunAll.sql" />
  </ItemGroup>
</Project>